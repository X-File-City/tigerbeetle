          "type": "click-file",
          "description": "Click linux.zig to see the io_uring production I/O implementation",
          "target": "src/io/linux.zig"
        }
      ]
    },
    {
      "id": "testing-infrastructure",
      "title": "Testing — Simulation & Fuzzing",
      "description": "The VOPR simulator runs an entire cluster on a single thread, injecting storage faults, network partitions, and timing variations. cluster.zig provides in-process simulation, and the Vortex framework drives end-to-end integration tests. 18 fuzz test modules are spread throughout the codebase.",
      "focusDirectory": "src/testing",
      "colorMode": "fileTypes",
      "estimatedTime": 45,
      "highlightLayers": [
        {
          "id": "simulation",
          "name": "Simulation Engine",
          "color": "#ef4444",
          "items": [
            { "path": "src/testing/cluster.zig", "type": "file" },
