{
  "id": "tigerbeetle-intro",
  "title": "Welcome to TigerBeetle",
  "description": "A guided tour of TigerBeetle — a high-performance financial transactions database built in Zig. Explore the consensus protocol, storage engine, accounting logic, client libraries, and testing infrastructure.",
  "version": "1.0.0",
  "audience": "New Contributors & Engineers",
  "prerequisites": [
    "Basic understanding of databases and distributed systems",
    "Familiarity with systems programming concepts"
  ],
  "steps": [
    {
      "id": "overview",
      "title": "The Big Picture",
      "description": "TigerBeetle is a financial transactions database built for mission-critical safety and extreme performance. Written entirely in Zig, the layout is simple: src/ holds all source code, docs/ has documentation, and build.zig drives the build system.",
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "estimatedTime": 30,
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover over the src directory to see the core codebase",
          "target": "src"
        }
      ]
    },
    {
      "id": "core-modules",
      "title": "Core Source Modules",
      "description": "The src/ directory contains everything. Key files at the root include state_machine.zig (accounting engine), constants.zig (configuration), vopr.zig (simulation tester), and tigerbeetle.zig (entry point). Each major subsystem lives in its own subdirectory.",
      "focusDirectory": "src",
      "colorMode": "fileTypes",
      "estimatedTime": 45,
      "highlightLayers": [
        {
          "id": "entry-points",
          "name": "Key Entry Points",
          "color": "#f59e0b",
          "items": [
            { "path": "src/tigerbeetle.zig", "type": "file" },
            { "path": "src/state_machine.zig", "type": "file" },
            { "path": "src/constants.zig", "type": "file" },
            { "path": "src/vopr.zig", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "click-file",
          "description": "Click state_machine.zig — the heart of TigerBeetle's accounting logic",
          "target": "src/state_machine.zig"
        }
      ]
    },
    {
      "id": "consensus-protocol",
      "title": "VSR — Consensus Protocol",
      "description": "TigerBeetle uses Viewstamped Replication (VSR) for distributed consensus across a 6-replica cluster. replica.zig is the core state machine, journal.zig manages the write-ahead log, and grid.zig provides block storage. The protocol uses flexible quorums — 3 replicas for durability, 4 for view change.",
      "focusDirectory": "src/vsr",
      "colorMode": "fileTypes",
      "estimatedTime": 60,
      "highlightLayers": [
        {
          "id": "vsr-core",
          "name": "Core Consensus",
          "color": "#3b82f6",
          "items": [
            { "path": "src/vsr/replica.zig", "type": "file" },
            { "path": "src/vsr/journal.zig", "type": "file" },
            { "path": "src/vsr/client.zig", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "fill"
        },
        {
          "id": "vsr-storage",
          "name": "Storage & Recovery",
          "color": "#10b981",
          "items": [
            { "path": "src/vsr/grid.zig", "type": "file" },
            { "path": "src/vsr/superblock.zig", "type": "file" },
            { "path": "src/vsr/free_set.zig", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "click-file",
          "description": "Click replica.zig — the largest file in the repo and the core of consensus",
          "target": "src/vsr/replica.zig"
        }
      ],
      "resources": [
        {
          "title": "VSR Internals Documentation",
          "url": "docs/internals/vsr.md",
          "type": "documentation"
        }
      ]
    },
    {
      "id": "storage-engine",
      "title": "LSM — Storage Engine",
      "description": "Data is stored in a Log-Structured Merge Tree forest — multiple specialized trees for different value types. forest.zig orchestrates the trees, tree.zig implements each one, and compaction.zig runs deterministic background compaction to bound tail latency.",
      "focusDirectory": "src/lsm",
      "colorMode": "fileTypes",
      "estimatedTime": 60,
      "highlightLayers": [
        {
          "id": "lsm-core",
          "name": "Core LSM",
          "color": "#8b5cf6",
          "items": [
            { "path": "src/lsm/forest.zig", "type": "file" },
            { "path": "src/lsm/tree.zig", "type": "file" },
            { "path": "src/lsm/compaction.zig", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "fill"
        },
        {
          "id": "lsm-manifest",
          "name": "Manifest & Metadata",
          "color": "#ec4899",
          "items": [
            { "path": "src/lsm/manifest.zig", "type": "file" },
            { "path": "src/lsm/manifest_log.zig", "type": "file" },
            { "path": "src/lsm/manifest_level.zig", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "click-file",
          "description": "Click forest.zig to see how multiple LSM trees are orchestrated",
          "target": "src/lsm/forest.zig"
        }
      ],
      "resources": [
        {
          "title": "LSM Internals Documentation",
          "url": "docs/internals/lsm.md",
          "type": "documentation"
        }
      ]
    },
    {
      "id": "state-machine",
      "title": "State Machine — Accounting Logic",
      "description": "TigerBeetle's double-entry bookkeeping engine. Supports creating accounts and transfers with pending, posted, and voided states. The state machine is physically deterministic — the same input produces byte-for-byte identical state across all replicas.",
      "focusDirectory": "src/state_machine",
      "colorMode": "fileTypes",
      "estimatedTime": 45,
      "highlightLayers": [
        {
          "id": "accounting",
          "name": "Accounting Engine",
          "color": "#f59e0b",
          "items": [
            { "path": "src/state_machine.zig", "type": "file" },
            { "path": "src/state_machine", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "accounting-tests",
          "name": "Accounting Tests",
          "color": "#ef4444",
          "items": [
            { "path": "src/state_machine_tests.zig", "type": "file" },
            { "path": "src/state_machine_fuzz.zig", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover over the state_machine directory to see the workload and auditor modules",
          "target": "src/state_machine"
        }
      ]
    },
    {
      "id": "client-libraries",
      "title": "Client Libraries — 7 Languages",
      "description": "Client libraries for Go, Python, Rust, Java, .NET, Node.js, and C. All wrap the same Zig-compiled shared library (libtb_client) with language-specific bindings, so every client gets identical networking and batching behavior.",
      "focusDirectory": "src/clients",
      "colorMode": "fileTypes",
      "estimatedTime": 45,
      "highlightLayers": [
        {
          "id": "client-langs",
          "name": "Client Language Bindings",
          "color": "#06b6d4",
          "items": [
            { "path": "src/clients/go", "type": "directory" },
            { "path": "src/clients/python", "type": "directory" },
            { "path": "src/clients/rust", "type": "directory" },
            { "path": "src/clients/java", "type": "directory" },
            { "path": "src/clients/dotnet", "type": "directory" },
            { "path": "src/clients/node", "type": "directory" },
            { "path": "src/clients/c", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border"
        }
      ],
      "interactiveActions": [
        {
          "type": "explore",
          "description": "Explore the client directories — each follows the same shared-library wrapper pattern"
        }
      ]
    },
    {
      "id": "io-layer",
      "title": "I/O Layer — Platform Abstraction",
      "description": "Platform-specific I/O abstraction. Linux uses io_uring, macOS uses kqueue, Windows uses IOCP. test.zig provides a mock backend so the entire database can be tested in simulation without real I/O.",
      "focusDirectory": "src/io",
      "colorMode": "fileTypes",
      "estimatedTime": 30,
      "highlightLayers": [
        {
          "id": "io-platforms",
          "name": "Platform Implementations",
          "color": "#f97316",
          "items": [
            { "path": "src/io/linux.zig", "type": "file" },
            { "path": "src/io/darwin.zig", "type": "file" },
            { "path": "src/io/windows.zig", "type": "file" }
          ],
          "opacity": 0.8,
